#!/usr/bin/env bash
set -euo pipefail
# arc-close <arc_dir> "<one-line verdict>" [--stop=falsified|no-progress|converged|<other>]
#   ★2-phase close: 1st run drafts _SUMMARY only (no seal) → fill blanks → re-run gate-checks & archives.
#   Gates: ① "(fill in)" left  = refuse   ② falsified/KILL → KILL-defense 5-check ("(unfilled)" left = refuse)
#   → guards against premature closure. Then STATE records CLOSED, _SUMMARY is sealed, arc moves to ../_archive/.
#   ★stop_reason distinguishes 'falsified' vs 'no-progress' vs 'converged' (generic ⇒ no-progress only).
#   ★Optional: seal the close into an append-only ledger (mirror-stack `am`, content-hash = _SUMMARY). Best-effort.
#   Negatives / retractions are recorded indelibly (no silent edits).

ARC_DIR="${1:-}"; VERDICT="${2:-}"; STOP="converged"
for arg in "${@:3}"; do
  case "$arg" in --stop=*) STOP="${arg#--stop=}" ;; esac
done
if [ -z "$ARC_DIR" ] || [ -z "$VERDICT" ]; then
  echo "usage: arc-close <arc_dir> \"<one-line verdict>\" [--stop=falsified|no-progress|converged]"
  exit 1
fi
[ -d "$ARC_DIR" ] || { echo "arc dir not found: $ARC_DIR"; exit 1; }

ARC_DIR="$(cd "$ARC_DIR" && pwd)"
ARC="$(basename "$ARC_DIR")"
ARCS_DIR="$(cd "$ARC_DIR/.." && pwd)"
ARCHIVE_DIR="$ARCS_DIR/_archive"
TODAY=$(date +%Y-%m-%d)
TS_ISO=$(date -Iseconds 2>/dev/null || date +"%Y-%m-%dT%H:%M:%S")

# portable in-place edit (GNU + BSD/macOS sed): sed writes to a temp file, then mv.
sed_inplace() { # sed_inplace <sed-expr> <file>
  sed "$1" "$2" > "$2.tmp" && mv "$2.tmp" "$2"
}

# thread status In-Progress → Closed
ARC_FILE="$ARC_DIR/ARC/${ARC}.md"
[ -f "$ARC_FILE" ] && sed_inplace 's/^status: "In-Progress"/status: "Closed"/' "$ARC_FILE"

# is this a KILL-type close? (stop=falsified or verdict mentions KILL)
IS_KILL="no"
case "$STOP" in falsified) IS_KILL="yes" ;; esac
case "$VERDICT" in *KILL*|*kill*) IS_KILL="yes" ;; esac

# ── ① sealed kill-condition injection ─────────────────────────────────────────────────────────
# If a pre-registration seal is linked to this arc (.prereg = claim_id + ledger), the harness INJECTS
# the verbatim sealed kill-condition into the record instead of trusting an agent-typed field. The agent
# is not the author of the condition, so it cannot be silently widened at close (post-hoc goalpost move).
# NOTE: this fixes the *condition* by reference; whether the result triggers it remains a judgment.
extract_kill() { # extract_kill <ledger> <claim_id> → verbatim kill_condition (whitespace-collapsed), else empty
  [ -f "$1" ] || return 0
  python3 - "$1" "$2" 2>/dev/null <<'PY'
import json, sys
led, cid = sys.argv[1], sys.argv[2]
for line in open(led, encoding='utf-8', errors='ignore'):
    line = line.strip()
    if not line: continue
    try: d = json.loads(line)
    except Exception: continue
    if d.get('claim_id') == cid and d.get('kill_condition'):
        print(' '.join(str(d['kill_condition']).split())); break
PY
}
PREREG="$ARC_DIR/.prereg"
SEAL_CLAIM=""; SEAL_LEDGER=""; SEAL_KILL=""
if [ -f "$PREREG" ]; then
  SEAL_CLAIM="$(sed -n '1p' "$PREREG")"; SEAL_LEDGER="$(sed -n '2p' "$PREREG")"
  SEAL_KILL="$(extract_kill "$SEAL_LEDGER" "$SEAL_CLAIM")"
fi

emit_kill_defense() { # KILL-defense section: sealed → inject verbatim condition; unsealed → attestation-only
  echo ""
  echo "## 🛡️ KILL-defense check (anti-premature-closure — all must be filled to seal)"
  if [ -n "$SEAL_KILL" ]; then
    echo "**Sealed kill-condition** (verbatim from seal \`$SEAL_CLAIM\` — harness-injected, do not edit):"
    printf '  > %s\n' "$SEAL_KILL"
    echo "- **Result triggers the sealed condition?**: (unfilled) ← the condition above is fixed by the seal; assert only that the result meets it (a judgment — not the condition)."
  else
    echo "> ⚠️ UNSEALED close — no pre-registration linked (arc-prereg). Kill-wording cannot be machine-anchored,"
    echo "> so this close is attestation-only. Seal the kill-condition (mirror-stack) and link it (arc-prereg) to"
    echo "> have the harness inject the verbatim condition instead of trusting a typed field."
    echo "- **Kill wording match**: (unfilled) ← does it hit the pre-registered kill-condition verbatim (no post-hoc widening)?"
  fi
  echo "- **Anchor (positive control) reproduced**: (unfilled) ← positive control converges/reproduces in the same experiment. Anchor failure = verdict void."
  echo "- **Independent angles converged (≥2)**: (unfilled) ← evidence you did not close on a single angle's negative alone."
  echo "- **Implementation defect ruled out**: (unfilled) ← the mechanism was implemented correctly (a sloppy impl losing ≠ mechanism useless)."
  echo "- **Catalog cross-check**: (unfilled) ← known measurement-illusion pattern? (catalog id, or 'none')."
}

SUMMARY="$ARC_DIR/_SUMMARY_${ARC}.md"

# ── 1st run: draft only, stop (no seal) ──
if [ ! -f "$SUMMARY" ]; then
  cat > "$SUMMARY" << MDEOF
# 🏛️ Arc closed — ${ARC}

- **Closed**: ${TODAY} (${TS_ISO})
- **stop_reason**: ${STOP}   (falsified / no-progress / converged)
- **Verdict**: ${VERDICT}

## What was closed (the conclusion)
- (fill in)

## What was NOT closed / out of scope
- (fill in)

## Evidence / artifacts
- Deliberation: [ARC/${ARC}.md](ARC/${ARC}.md)
- Spec: [0001_spec.md](0001_spec.md)
- Tickets: tickets/

> Discipline: negatives and retractions are recorded indelibly. Numbers only after checking against evidence.
MDEOF
  [ "$IS_KILL" = "yes" ] && emit_kill_defense >> "$SUMMARY"
  echo "📝 _SUMMARY drafted (not sealed): $SUMMARY"
  [ "$IS_KILL" = yes ] && [ -n "$SEAL_KILL" ] && echo "   🔒 sealed kill-condition injected from seal $SEAL_CLAIM (not agent-authored)."
  [ "$IS_KILL" = yes ] && [ -z "$SEAL_KILL" ] && echo "   ⚠️ UNSEALED — no prereg linked (arc-prereg); kill-wording is attestation-only."
  echo "   Fill the blanks (fill in$([ "$IS_KILL" = yes ] && echo ' / unfilled')), then re-run the same command to gate-check and archive."
  exit 0
fi

# ── 2nd run: gate-check then seal ──
if grep -q '(fill in)' "$SUMMARY"; then
  echo "⛔ seal refused: '(fill in)' blanks remain in _SUMMARY — fill and re-run."
  grep -n 'fill in' "$SUMMARY" | sed 's/^/    /'
  exit 4
fi
if [ "$IS_KILL" = "yes" ]; then
  if ! grep -q 'KILL-defense check' "$SUMMARY"; then
    emit_kill_defense >> "$SUMMARY"
    echo "⛔ seal refused: KILL-type close without a 🛡️ KILL-defense check — section added. Fill it and re-run."
    exit 5
  fi
  # ① the harness owns the sealed-condition line — it must remain the verbatim seal (no silent widening)
  if [ -n "$SEAL_KILL" ] && ! grep -qxF "  > $SEAL_KILL" "$SUMMARY"; then
    echo "⛔ seal refused: the harness-injected sealed kill-condition line was edited — it must stay verbatim from seal \`$SEAL_CLAIM\`."
    exit 5
  fi
  if grep -q '(unfilled)' "$SUMMARY"; then
    echo "⛔ seal refused: 🛡️ KILL-defense items remain unfilled — anti-premature-closure gate."
    grep -n 'unfilled' "$SUMMARY" | sed 's/^/    /'
    exit 5
  fi
  # minimal substance check — can't judge truth, but reject self-evident evasions (a bare "yes", ".", etc.)
  while IFS= read -r vline; do
    case "$vline" in "- **"*"**:"*) ;; *) continue ;; esac
    vlabel="$(printf '%s' "$vline" | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')"
    # answer extraction via python (Unicode-safe — sed's multibyte ← match is locale-fragile)
    vans="$(printf '%s' "$vline" | python3 -c 'import sys,re; s=sys.stdin.read(); s=re.sub(r"^- \*\*[^*]+\*\*:\s*","",s); s=re.sub(r"\s*←.*$","",s); sys.stdout.write(s.strip())')"
    vlow="$(printf '%s' "$vans" | tr '[:upper:]' '[:lower:]')"
    case "$vlow" in ""|y|yes|ok|okay|na|n/a|done|.|-|x|pass|true|good|yep|sure|n)
      echo "⛔ seal refused: KILL-defense '$vlabel' answer too trivial: '$vans'"; exit 5 ;;
    esac
    case "$vlabel" in
      *[Cc]atalog*)  # a catalog id, or the literal 'none'
        case "$vlow" in none) : ;; *) printf '%s' "$vans" | grep -qE '[A-Za-z0-9_]{3,}' \
          || { echo "⛔ seal refused: catalog cross-check needs a catalog id or 'none': '$vans'"; exit 5; } ;; esac ;;
      *[Aa]nchor*)   # a number, or a seal/reproduction reference
        printf '%s' "$vlow" | grep -qE '[0-9]|seal|anchor|reproduc|converg|hash' \
          || { echo "⛔ seal refused: anchor answer needs a number or a seal/reproduction reference: '$vans'"; exit 5; } ;;
      *)             # otherwise require a little substance
        [ "${#vans}" -ge 6 ] || { echo "⛔ seal refused: KILL-defense '$vlabel' answer too short: '$vans'"; exit 5; } ;;
    esac
  done < <(sed -n '/KILL-defense check/,$p' "$SUMMARY")
fi

echo "ARC_CLOSED ${TODAY} stop=${STOP} — ${VERDICT}" >> "$ARC_DIR/STATE.md"

mkdir -p "$ARCHIVE_DIR"
mv "$ARC_DIR" "$ARCHIVE_DIR/"
SEALED="$ARCHIVE_DIR/$ARC/_SUMMARY_${ARC}.md"

# ── optional: seal into append-only ledger (best-effort; skips if `am` absent) ──
SEAL_MSG="no ledger — file only (install mirror-stack for sealing)"
if command -v am >/dev/null 2>&1; then
  if am record --agent yeoul --action arc-close --target "$ARC" \
       --payload "{\"stop_reason\":\"${STOP}\"}" \
       --content-file "$SEALED" >/dev/null 2>&1; then
    SEAL_MSG="✅ sealed into ledger (content-hash = _SUMMARY → tamper-evident)"
  else
    SEAL_MSG="⚠️ am record failed (skipped)"
  fi
fi

echo "┌─ Arc closed ─┐"
echo "  arc        : $ARC"
echo "  stop_reason: $STOP"
echo "  verdict    : $VERDICT"
echo "  seal       : $SEAL_MSG"
echo "  archived   : $ARCHIVE_DIR/$ARC/  (gates passed — blanks & KILL-defense checked)"
